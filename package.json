{
  "name": "voisona-talk-api",
  "version": "1.2.0",
  "type": "module",
  "description": "A TypeScript library for the VoiSona Talk API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WindSekirun/voisona-talk-api"
  },
  "bugs": {
    "url": "https://github.com/WindSekirun/voisona-talk-api/issues"
  },
  "homepage": "https://github.com/WindSekirun/voisona-talk-api#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "release": "release-it --ci",
    "docs:api": "typedoc --entryPoints src/index.ts --out docs/api --plugin typedoc-plugin-markdown --readme none && node scripts/docs-post-process.js",
    "docs:dev": "pnpm run docs:api && vitepress dev docs",
    "docs:build": "pnpm run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "node -e \"if (!process.env.CI) require('child_process').spawnSync('husky', {shell: true, stdio: 'inherit'})\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@catppuccin/vitepress": "^0.1.2",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "release-it": "^20.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "path-browserify": "^1.0.1"
  }
}
